;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="The Labyrinth"
config/description="Jogo de exploração em primeira pessoa num jardim labiríntico abandonado."
run/main_scene="res://cenas/menus/menu_inicial.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GerenciadorAudio="*res://scripts/nucleo/gerenciador_audio.gd"
GerenciadorCenas="*res://scripts/nucleo/gerenciador_cenas.gd"
GerenciadorSave="*res://scripts/save/gerenciador_save.gd"
Configuracoes="*res://scripts/nucleo/configuracoes.gd"
GerenciadorJogo="*res://scripts/nucleo/gerenciador_jogo.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"

